# ============================================================
# NexVid Environment Variables
# ============================================================
# Copy this file to .env.local and fill in values.
#
# Where each variable is used:
#   [PAGES]  = Cloudflare Pages edge functions (src/app/api/*)
#   [WORKER] = Cloudflare Worker (worker/src/index.ts)
#   [LOCAL]  = Local development only
#   [BOTH]   = Used in both Pages and Worker wrangler.toml
# ============================================================

# ── APP CONFIGURATION ──
# [BOTH] Primary production URL for canonical links and callbacks.
APP_BASE_URL=https://nexvid.online

# ── SECURITY & AUTHENTICATION ──
# [WORKER] Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=https://nexvid.online,https://www.nexvid.online,http://localhost:3000
# [WORKER] Session lifetime in days.
SESSION_TTL_DAYS=30
# [BOTH] Shared internal API secret for inter-service auth.
INTERNAL_API_SECRET=nv_secret_9d98265aac54bfc8_WAW

# ── CLOUDFLARE TURNSTILE ──
# [PAGES] Public site key for the client widget.
TURNSTILE_SITE_KEY=
# [WORKER] Secret key for server-side Turnstile token verification.
TURNSTILE_SECRET_KEY=

# ── EXTERNAL MEDIA APIS ──
# [LOCAL] Optional TMDB API key override (falls back to built-in public key).
TMDB_API_KEY=
# [PAGES] OMDB API key for external ratings endpoint.
OMDB_API_KEY=
# [PAGES] Groq API key for AI assistant endpoint.
GROQ_API_KEY=
# [PAGES] Wyzie API key for subtitles endpoint.
WYZIE_KEY=
# [PAGES] TIDB API key for intro/outro segments.
TIDB_API_KEY=
# [PAGES] TIDB base URL.
NEXT_PUBLIC_TIDB_URL=https://api.theintrodatabase.com

# ── PROXY & RESOLVER ──
# [WORKER] Whitelist of domains the worker proxy can access.
PROXY_ALLOWED_HOSTS=*.febbox.com,febbox.com,*.tmdb.org,api.themoviedb.org,image.tmdb.org,sub.wyzie.ru,api.theintrodb.org
# [PAGES] Worker API URL used by cloud sync, AI assistant, and HLS proxy resolver.
NEXT_PUBLIC_API_URL=https://nexvid-proxy.piotrunius.workers.dev
# [PAGES] Direct resolver URL (falls back to NEXT_PUBLIC_API_URL).
DIRECT_RESOLVER_URL=

# ── STORAGE - FEBBOX ──
# [PAGES] Server-side credentials for FebBox API.
FEBBOX_CLIENT_ID=
FEBBOX_CLIENT_SECRET=

# ── WORKER EMAIL ──
# [WORKER] From address for notification emails.
EMAIL_FROM=NexVid <noreply@nexvid.pages.dev>

# ── NOTIFICATIONS ──
# [LOCAL] Discord webhook for release notifications (scripts/ship.mjs).
DISCORD_WEBHOOK=

# ============================================================
# DASHBOARD SECRETS (set via Cloudflare dashboard, not in .env)
# ============================================================
# These are the secrets you need to set in the Cloudflare Pages
# dashboard under Settings > Environment Variables:
#
# GROQ_API_KEY          - Groq AI API key
# OMDB_API_KEY          - OMDB ratings API key
# TIDB_API_KEY          - IntroDB API key
# WYZIE_KEY             - Wyzie subtitles API key
# FEBBOX_CLIENT_ID      - FebBox client ID
# FEBBOX_CLIENT_SECRET  - FebBox client secret
# TURNSTILE_SITE_KEY    - Turnstile public key (plaintext)
# DIRECT_RESOLVER_URL   - Optional resolver URL (if different from worker)
# NEXT_PUBLIC_API_URL   - Worker URL (secret)
# APP_BASE_URL          - Production URL (plaintext)
