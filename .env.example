# NexVid Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# TMDB API (required)
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# Cloudflare Worker Proxy URL
NEXT_PUBLIC_PROXY_URL=https://nexvid-proxy.your-account.workers.dev

# TheIntroDataBase (TIDB) - no key needed for public API
NEXT_PUBLIC_TIDB_URL=https://api.theintrodatabase.com

# Cloudflare worker API (auth/settings/watchlist)
NEXT_PUBLIC_API_URL=https://nexvid-proxy.your-account.workers.dev

# Dev mode - set to true for mock streams (Big Buck Bunny)
NEXT_PUBLIC_DEV_MODE=false

# FebBox API (server-side only - never exposed to client)
FEBBOX_CLIENT_ID=
FEBBOX_CLIENT_SECRET=

# Cloudflare Turnstile (optional, for login protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
