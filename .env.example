# [APP CONFIGURATION]
# The primary production URL of the application
APP_BASE_URL=https://nexvid.online

# [SECURITY & AUTHENTICATION]
# Comma-separated list of origins allowed to bypass CORS
ALLOWED_ORIGINS=https://nexvid.online,https://www.nexvid.online,http://localhost:3000
# Duration of user sessions in days
SESSION_TTL_DAYS=30

# [CLOUDFLARE TURNSTILE]
# Private secret key for server-side response validation
TURNSTILE_SECRET_KEY=

# [EXTERNAL MEDIA APIS]
# TMDB API Key - Required for movie/show metadata
# OMDB API Key - Used for external ratings (Public & Private)
OMDB_API_KEY=
# Groq API Key - Required for AI-powered features
GROQ_API_KEY=
# Wyzie API Key - Specific resolver or service access key
WYZIE_KEY=

# Private API key for TIDB authentication
TIDB_API_KEY=

# [PROXY & RESOLVER SETTINGS]
# Cloudflare Worker URL used as a proxy to bypass provider restrictions
NEXT_PUBLIC_PROXY_URL=
# Whitelist of domains the proxy is permitted to access
PROXY_ALLOWED_HOSTS=*.febbox.com,febbox.com,*.tmdb.org,api.themoviedb.org,sub.wyzie.ru
# Direct resolver URL for restricted CDN sources (Vidnest, i-arch, etc.)
DIRECT_RESOLVER_URL=

# [STORAGE - FEBBOX]
# Server-side credentials for FebBox API integration
FEBBOX_CLIENT_ID=
FEBBOX_CLIENT_SECRET=

# [NOTIFICATIONS]
# Discord Webhook URL for automated system logs and notifications
DISCORD_WEBHOOK=
