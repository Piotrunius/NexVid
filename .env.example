# [APP CONFIGURATION]
# [PAGES + WORKER] Primary production URL used for canonical links and internal callbacks.
APP_BASE_URL=https://nexvid.online

# [SECURITY & AUTHENTICATION]
# [WORKER] List of origins allowed by worker CORS/auth endpoints.
ALLOWED_ORIGINS=https://nexvid.online,https://www.nexvid.online,http://localhost:3000
# [WORKER] Session lifetime in days.
SESSION_TTL_DAYS=30

# [CLOUDFLARE TURNSTILE]
# [PAGES] Public site key for client widget rendering.
TURNSTILE_SITE_KEY=
# [WORKER] Private secret key used to validate Turnstile tokens server-side.
TURNSTILE_SECRET_KEY=

# [EXTERNAL MEDIA APIS]
# [LOCAL] Optional TMDB API key override for local testing (falls back to built-in public key).
TMDB_API_KEY=
# [PAGES] OMDB API key for external ratings endpoint.
OMDB_API_KEY=
# [PAGES] Groq API key for AI assistant endpoint.
GROQ_API_KEY=
# [PAGES] Wyzie API key for subtitles endpoint.
WYZIE_KEY=
# [PAGES] TIDB API key for intro/outro segments proxy submit flow.
TIDB_API_KEY=

# [PROXY & RESOLVER SETTINGS]
# [WORKER] Whitelist of domains the worker proxy can access.
PROXY_ALLOWED_HOSTS=*.febbox.com,febbox.com,*.tmdb.org,api.themoviedb.org,sub.wyzie.ru,*.vixsrc.to,vixsrc.to,*.vix-content.net,vix-content.net
# [PAGES] Optional direct resolver URL for problematic CDN sources.
DIRECT_RESOLVER_URL=

# [STORAGE - FEBBOX]
# [PAGES] Server-side credentials for FebBox API integration.
FEBBOX_CLIENT_ID=
FEBBOX_CLIENT_SECRET=

# [NOTIFICATIONS]
# [LOCAL] Used by scripts/ship.mjs for Discord release notifications.
DISCORD_WEBHOOK=
