{
  "name": "nexvid-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "bun scripts/generate-build-info.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,mjs,json,md,css,scss,html}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,mjs,json,md,css,scss,html}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "proxy:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "pages:build-output": "bun scripts/generate-build-info.mjs && bunx @cloudflare/next-on-pages@latest",
    "pages:prepare": "bun scripts/prepare-pages-output.mjs",
    "pages:deploy": "bun scripts/deploy-pages.mjs",
    "ship": "bun run format && bun scripts/ship.mjs",
    "prepare": "husky install"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "disable-devtool": "^0.3.9",
    "framer-motion": "^11.18.2",
    "fuse.js": "^7.3.0",
    "hls.js": "^1.6.16",
    "immer": "^10.2.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.15",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^2.6.1",
    "wyzie-lib": "^2.5.1",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "esbuild": "^0.27.4",
    "undici": "^7.24.0",
    "serialize-javascript": "^7.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0",
    "prettier": "^3.8.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,mjs,json,md,css,scss,html}": [
      "prettier --write"
    ]
  }
}
