{
  "name": "nexvid-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bun scripts/generate-build-info.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "proxy:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "pages:build-output": "bun scripts/generate-build-info.mjs && bunx @cloudflare/next-on-pages@latest",
    "pages:prepare": "bun scripts/prepare-pages-output.mjs",
    "pages:deploy": "bun scripts/deploy-pages.mjs",
    "ship": "bun scripts/ship.mjs"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "disable-devtool": "^0.3.9",
    "framer-motion": "^11.15.0",
    "fuse.js": "^7.0.0",
    "hls.js": "^1.5.0",
    "immer": "^10.1.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.15",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^2.6.1",
    "wyzie-lib": "^2.4.0",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "esbuild": "^0.27.4",
    "undici": "^7.24.0",
    "serialize-javascript": "^7.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/crypto-js": "^4.2.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.3",
    "wrangler": "^4.73.0"
  }
}
